    { "match": "leo",        "handle": "Leonardo-Corte",    "role": "iOS lead", "fullName": "Leonardo Corte" },
    { "match": "federico",   "handle": "fc200490-sketch",   "role": "Harness lead", "fullName": "Federico" },
    { "match": "fede",       "handle": "fc200490-sketch",   "role": "Harness lead", "fullName": "Federico" },
    { "match": "fc200490",   "handle": "fc200490-sketch",   "role": "Harness lead", "fullName": "Federico" }
  ]
