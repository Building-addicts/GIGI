# GIGI harness server — env vars (override config.json)
# Copia in .env e popola

# Paths (opzionale, default = relative to server/)
# HARNESS_CONFIG=/path/to/config.json
# HARNESS_LOGS_DIR=/path/to/logs
# HARNESS_WATCHERS=/path/to/watchers.json

# Auth iOS (OBBLIGATORIO in prod)
HARNESS_SHARED_SECRET=genera_token_random_32_char

# Claude CLI
CLAUDE_BIN=/Users/TUO_USER/.local/bin/claude
CLAUDE_TIMEOUT_MS=600000
CLAUDE_MODEL=claude-opus-4-7

# Computer-use (fase 14)
ANTHROPIC_API_KEY=sk-ant-...

# APNS (fase 15)
APNS_KEY_PATH=/Users/TUO_USER/.gigi/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.leonardocorte.gigi
APNS_PRODUCTION=false

# Memory backend (fase 13)
MEMORY_BACKEND=json
